{
  "name": "nestjs-auth-template",
  "version": "1.0.0",
  "description": "NestJS backend template with authentication and users",
  "author": "Qusai Albonni",
  "private": true,
  "license": "UNLICENSED",
  "type": "commonjs",
  "scripts": {
    "build": "nest build",
    "db:rm:dev": "docker compose rm dev-postgres -s -f -v",
    "db:up:dev": "docker compose up dev-postgres -d",
    "db:restart:dev": "npm run db:rm:dev && npm run db:up:dev && timeout 2",
    "db:rm:test": "docker compose rm test-postgres -s -f -v",
    "db:up:test": "docker compose up test-postgres -d",
    "db:restart:test": "npm run db:rm:test && npm run db:up:test && timeout 2",
    "migration:generate": "npx ts-node -P ./tsconfig.json -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate -d ./src/database/migration.config.ts ./src/database/migrations/migration",
    "migration:run": "npx ts-node -P ./tsconfig.json -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d ./src/database/migration.config.ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "seed": "ts-node -P ./tsconfig.json -r tsconfig-paths/register ./src/database/seeders/seed.ts",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "create-admin": "ts-node -P ./tsconfig.json -r tsconfig-paths/register src/scripts/create-admin",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "npx dotenv-cli -e .env.test.local -- jest --runInBand --forceExit --no-cache --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@2toad/profanity": "^3.1.1",
    "@adminjs/express": "^6.1.1",
    "@adminjs/nestjs": "^6.1.0",
    "@adminjs/typeorm": "^5.0.1",
    "@aws-sdk/client-rekognition": "^3.758.0",
    "@aws-sdk/client-s3": "^3.744.0",
    "@aws-sdk/s3-request-presigner": "^3.744.0",
    "@keyv/redis": "^4.3.4",
    "@logtail/node": "^0.5.5",
    "@logtail/winston": "^0.5.5",
    "@nest-lab/throttler-storage-redis": "^1.1.0",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/swagger": "^8.1.1",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^11.0.0",
    "@sentry/nestjs": "^9.5.0",
    "@types/async-retry": "^1.4.9",
    "@types/pdf-parse": "^1.1.5",
    "@vonage/auth": "^1.12.0",
    "@vonage/server-sdk": "^3.19.4",
    "@vonage/sms": "^1.17.3",
    "adminjs": "^7.8.15",
    "argon2": "^0.41.1",
    "async-retry": "^1.3.3",
    "axios": "^1.9.0",
    "cache-manager": "^6.4.2",
    "cacheable": "^1.8.10",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.0",
    "connect-redis": "^8.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "env-var": "^7.5.0",
    "express-session": "^1.18.1",
    "file-type": "^16.5.4",
    "helmet": "^8.0.0",
    "humanize-duration-ts": "^2.1.1",
    "ioredis": "^5.6.1",
    "libphonenumber-js": "^1.12.5",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "nest-winston": "^1.10.2",
    "nestjs-i18n": "^10.5.1",
    "nestjs-typeorm-paginate": "^4.0.4",
    "pactum": "^3.7.6",
    "passport": "^0.7.0",
    "passport-http-bearer": "^1.0.1",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "retry": "^0.13.1",
    "rxjs": "^7.8.1",
    "twilio": "^5.4.5",
    "typeorm": "^0.3.22",
    "typeorm-extension": "^3.7.0",
    "ultramsg-whatsapp-api": "^1.0.2",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "winston-cloudwatch": "^6.3.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@flydotio/dockerfile": "^0.7.10",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@swc/cli": "^0.5.0",
    "@swc/core": "^1.10.7",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/multer-s3": "^3.0.3",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^15.14.0",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.3.2",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.20.0",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1",
    "webpack-node-externals": "^3.0.0"
  }
}
